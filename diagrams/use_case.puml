@startuml
left to right direction
skinparam packageStyle rectangle

actor "Користувач" as User
actor "Адміністратор" as Admin

rectangle "Touch Up Smart System" {
  usecase "UC-01: Обрати категорію події" as UC01
  usecase "UC-02: Отримати випадковий факт" as UC02
  usecase "UC-03: Доступ до офлайн-контенту" as UC03
  usecase "UC-04: Зберегти в «Обране»" as UC04
  usecase "UC-05: Модерувати контент" as UC05
  usecase "UC-06: Налаштувати Push-сповіщення" as UC06
}

User --> UC01
User --> UC02
User --> UC03
User --> UC04
User --> UC06

Admin --> UC05
@enduml
